<decoder name="ses-json-stdout">
    <program_name>wazuh-ses-connector</program_name>
    <prematch>\d\d\d\d-\d\d-\d\dT\d\d:\d\d:\d\d.\d+Z stdout F {\.*}</prematch>    
</decoder>

<decoder name="ses-json-log">
    <parent>ses-json-stdout</parent>
    <prematch>stdout F </prematch>
    <plugin_decoder offset="after_prematch">JSON_Decoder</plugin_decoder>
</decoder>
